# ============================================================
# Job Search Intelligence - Environment Configuration
# ============================================================

# ===== LinkedIn Configuration =====
# Required for LinkedIn authentication and API access
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here
LINKEDIN_LI_AT=your_linkedin_li_at_cookie_token_here

# LinkedIn API credentials (for advanced features)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# ===== Candidate Profile =====
# Your name as it appears in resume documents
CANDIDATE_NAME=Your Name
# Comma-separated list of your previous employers (used in LLM prompts)
CANDIDATE_EMPLOYERS=Employer One, Employer Two, Employer Three

# ===== Application Environment =====
# Development, production, or staging
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ===== AI Integration Configuration =====
# Set to true to enable AI analysis features (requires API key or local model)
# Options for AI_PROVIDER: claude, openai, ollama, llamacpp, local
AI_ENABLED=true
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.2

# Cloud AI API Keys (get from respective providers)
# Anthropic Claude API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OpenAI API key (alternative to Anthropic)
# OPENAI_API_KEY=your_openai_api_key_here

# ===== Culture Score (Glassdoor) Configuration =====
# Free-tier Glassdoor data via RapidAPI OpenWeb Ninja
# Setup (one-time, free, no credit card):
#   1. Sign up at https://rapidapi.com/
#   2. Search "Real-Time Glassdoor Data" by OpenWeb Ninja
#   3. Subscribe to BASIC (free) plan — 100 req/month
#   4. Paste your RapidAPI key below and set GLASSDOOR_API_ENABLED=true
RAPIDAPI_KEY=your_rapidapi_key_here
GLASSDOOR_API_ENABLED=true

# ===== Career Page Verification (Serper.dev) =====
# Free Google Search API for Phase 3 career page verification
# 2,500 free queries available at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ===== Local LLM Configuration =====
# Ollama settings (easiest local option)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Llama.cpp settings (for direct model loading)
# LLAMACPP_MODEL_PATH=/path/to/your/model.gguf
LLAMACPP_N_CTX=4096
LLAMACPP_N_THREADS=4

# Local model settings (generic local model path)
# LOCAL_MODEL_PATH=/path/to/your/local/model

# GPU acceleration (number of layers to offload to GPU)
LOCAL_GPU_LAYERS=0

# ===== Analysis Configuration =====
# Standard or advanced analysis mode
ANALYSIS_MODE=standard
AI_INSIGHTS=true
PERFORMANCE_MONITORING=true

# ===== Monitoring & Observability =====
MONITORING_ENABLED=true
PERFORMANCE_MONITORING=true

# ===== Rate Limiting Configuration =====
# Request delays (seconds) - adjust these to be more/less aggressive
RATE_LIMIT_MIN_DELAY=2.0
RATE_LIMIT_MAX_DELAY=5.0
RATE_LIMIT_PENALTY_DELAY=60

# Request limits per time period - set conservative limits to avoid blocking
RATE_LIMIT_MAX_PER_MINUTE=10
RATE_LIMIT_MAX_PER_HOUR=300
RATE_LIMIT_MAX_PER_DAY=5000

# Conservative mode settings - enable for maximum safety
RATE_LIMIT_CONSERVATIVE_MODE=false
RATE_LIMIT_CONSERVATIVE_MULTIPLIER=2.0

# Session management
RATE_LIMIT_SESSION_TIMEOUT=3600
RATE_LIMIT_MAX_CONSECUTIVE_ERRORS=5
RATE_LIMIT_COOLDOWN_AFTER_ERRORS=300

# Advanced settings
RATE_LIMIT_EXPONENTIAL_BACKOFF=true
RATE_LIMIT_RANDOMIZE_DELAYS=true
RATE_LIMIT_RESPECT_ROBOTS_TXT=true

# ===== Resource Management =====
MAX_CONCURRENT_REQUESTS=5
CONNECTION_POOL_SIZE=10

# ===== Storage Configuration =====
DATA_DIRECTORY=data
BACKUP_ENABLED=true

# ===== Notification Configuration =====
NOTIFICATIONS_ENABLED=true

# Email notifications (for sending alerts and reports)
EMAIL_ENABLED=true
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_email_app_password_here
EMAIL_RECIPIENTS=your_email@example.com

# Telegram notifications (optional - for real-time alerts)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== Database Configuration =====
# SQLite (default) - no configuration needed
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/db_name
# For MySQL: DATABASE_URL=mysql://user:password@localhost/db_name
# DATABASE_URL=sqlite:///job_search.db
